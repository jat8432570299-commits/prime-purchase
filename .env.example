PORT=3000
NODE_ENV=development
PUBLIC_BASE_URL=https://your-render-app.onrender.com

GOOGLE_SHEET_ID=14-a_PZVOs7vbsdtISAyEQH-MD-5zemvIp0JjBW8_Km8
GOOGLE_SERVICE_ACCOUNT_FILE=credentials/google-service-account.json
INVENTORY_SHEET_NAME=Inventory
ORDERS_SHEET_NAME=Orders
SETTINGS_SHEET_NAME=Settings
WEBHOOK_LOGS_SHEET_NAME=WebhookLogs
DEFAULT_ACCOUNT_PASSWORD=change_this_password

ADMIN_NUMBERS=918432570299
ACCOUNT_PRICE=100

# Unofficial WhatsApp API / IMB config
IMB_API_BASE_URL=https://secure-stage.imb.org.in
IMB_API_TOKEN=replace_with_your_token
IMB_WEBHOOK_SECRET=replace_if_provider_gives_one
IMB_MOCK_MODE=false
IMB_WHATSAPP_MOCK_MODE=false
IMB_PAYMENT_MOCK_MODE=false

# Keep these paths configurable because unofficial API panels often differ.
IMB_WHATSAPP_SEND_PATH=/api/send-message
IMB_PAYMENT_CREATE_PATH=/api/create-order
IMB_PAYMENT_STATUS_PATH=/api/check-order-status
PAYMENT_POLL_ENABLED=true
PAYMENT_POLL_INTERVAL_SECONDS=60

# Optional: header name used by IMB/unofficial API for token auth.
IMB_AUTH_HEADER=
IMB_AUTH_SCHEME=

# SMSQuicker WhatsApp API config
WHATSAPP_PROVIDER=smsquicker
SMSQUICKER_API_BASE_URL=https://smsquicker.com
SMSQUICKER_API_SECRET=replace_with_smsquicker_api_secret
SMSQUICKER_SEND_PATH=/api/send/whatsapp
SMSQUICKER_PHONE_FIELD=recipient
SMSQUICKER_MESSAGE_FIELD=message
SMSQUICKER_WHATSAPP_ACCOUNT=replace_with_whatsapp_account_unique_id
SMSQUICKER_TYPE=text
SMSQUICKER_MODE=devices
SMSQUICKER_CAMPAIGN=WhatsApp Inventory
SMSQUICKER_SIM=1

# Optional webhook verification token for simple GET verification.
WEBHOOK_VERIFY_TOKEN=change_this_verify_token
